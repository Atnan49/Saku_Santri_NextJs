# Environment Variables Template for Saku Santri

# 1. Database Connection (PostgreSQL / SQLite)
DATABASE_URL="postgresql://user:password@localhost:5432/saku_santri?schema=public"
# DATABASE_URL="file:./dev.db" # Alternatif SQLite untuk pengembangan lokal ringan

# 2. NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="super-secret-key-change-in-production"

# 3. Vercel Blob Storage Token (Untuk upload bukti bayar)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token_here"

# 4. WhatsApp Gateway API (Fonnte / Wablas Credentials)
WA_API_URL="https://api.fonnte.com/send"
WA_API_TOKEN="fonnte_or_wablas_api_token_here"

# 5. App Settings
NEXT_PUBLIC_APP_NAME="Saku Santri"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

