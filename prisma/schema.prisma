generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  username      String         @unique
  email         String?        @unique
  phone         String?        @unique
  passwordHash  String
  name          String
  role          UserRole
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  wali          WaliMurid?
  notifications Notification[]
}

model WaliMurid {
  id      String   @id @default(uuid()) @db.Uuid
  user    User     @relation(fields: [userId], references: [id])
  userId  String   @unique @db.Uuid
  alamat  String?
  siswa   Siswa[]
}

model Kelas {
  id      String   @id @default(uuid()) @db.Uuid
  name    String   @unique
  siswa   Siswa[]
}

model TahunAjaran {
  id       String   @id @default(uuid()) @db.Uuid
  year     String   @unique
  isActive Boolean  @default(false)
  tagihan  Tagihan[]
}

model Siswa {
  id            String    @id @default(uuid()) @db.Uuid
  nisn          String    @unique
  name          String
  kelas         Kelas     @relation(fields: [kelasId], references: [id])
  kelasId       String    @db.Uuid
  wali          WaliMurid @relation(fields: [waliId], references: [id])
  waliId        String    @db.Uuid
  potonganTetap Decimal   @default("0.0")
  tagihan       Tagihan[]
}

model JenisTagihan {
  id      String       @id @default(uuid()) @db.Uuid
  name    String
  type    TagihanType
  nominal Decimal
  tagihan Tagihan[]
}

model Tagihan {
  id             String         @id @default(uuid()) @db.Uuid
  siswa          Siswa          @relation(fields: [siswaId], references: [id])
  siswaId        String         @db.Uuid
  jenisTagihan   JenisTagihan   @relation(fields: [jenisTagihanId], references: [id])
  jenisTagihanId String         @db.Uuid
  tahunAjaran    TahunAjaran    @relation(fields: [tahunAjaranId], references: [id])
  tahunAjaranId  String         @db.Uuid
  nominalAwal    Decimal
  potongan       Decimal        @default("0.0")
  nominalAkhir   Decimal
  dueDate        DateTime
  period         String
  status         TagihanStatus  @default(BELUM_BAYAR)
  catatanTagihan String?
  pembayaran     Pembayaran?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Pembayaran {
  id              String   @id @default(uuid()) @db.Uuid
  tagihan         Tagihan  @relation(fields: [tagihanId], references: [id])
  tagihanId       String   @unique @db.Uuid
  buktiUrl        String?
  catatanWali     String?
  catatanAdmin    String?
  catatanBendahara String?
  verifiedAt      DateTime?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.Uuid
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  WALIMURID
  BENDAHARA
}

enum TagihanType {
  BULANAN
  TAHUNAN
}

enum TagihanStatus {
  BELUM_BAYAR
  MENUNGGU_VERIFIKASI_ADMIN
  MENUNGGU_APPROVAL_BENDAHARA
  LUNAS
  DITOLAK_ADMIN
  DITOLAK_BENDAHARA
}
